{
    "name": "@adyen/adyen-platform-experience-web-vue",
    "version": "0.0.0",
    "private": false,
    "type": "module",
    "main": "./dist/es/index.js",
    "module": "./dist/es/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/es/index.js"
        },
        "./style.css": "./dist/adyen-platform-experience-web-vue.css"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist"
    ],
    "scripts": {
        "start": "pnpm run storybook",
        "build": "vite build && vue-tsc -p tsconfig.build.json",
        "preview": "vite preview",
        "storybook": "node .storybook/dev.js",
        "storybook:build": "storybook build",
        "test": "cross-env TEST_ENV=1 vitest --config vite.config.ts"
    },
    "dependencies": {
        "@adyen/bento-vue3": "^1.86.0",
        "vue-i18n": "^11"
    },
    "peerDependencies": {
        "vue": "^3.3.0"
    },
    "devDependencies": {
        "@storybook/vue3": "^10.1.10",
        "@storybook/vue3-vite": "^10.1.10",
        "@types/node": "^24.10.13",
        "@vitejs/plugin-vue": "^6.0.3",
        "cross-env": "^10.1.0",
        "dotenv": "^16.4.7",
        "sass": "^1.77.6",
        "storybook": "^10.1.10",
        "terser": "^5.46.0",
        "typescript": "^5.8.3",
        "vite": "^7.3.0",
        "vite-plugin-vue-devtools": "^8.0.5",
        "vitest": "^4.0.18",
        "vue": "^3.5.26",
        "vue-tsc": "^2.2.4"
    }
}
