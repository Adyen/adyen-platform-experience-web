{
    "compilerOptions": {
        "allowJs": true,
        "moduleResolution": "bundler",
        "module": "esnext",
        "target": "esnext",
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "importHelpers": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "stripInternal": true,
        "jsxImportSource": "preact",
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@integration-components/types": [
                "packages/shared/types/src/index.ts"
            ],
            "@integration-components/types/*": [
                "packages/shared/types/src/*"
            ],
            "@integration-components/sdk-internal": [
                "packages/shared/lib/src/index.ts"
            ],
            "@integration-components/sdk-internal/*": [
                "packages/shared/lib/src/*"
            ],
            "@integration-components/reports/publish": [
                "packages/domains/reports/publish/src/index.ts"
            ]
        }
    }
}