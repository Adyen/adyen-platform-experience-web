{
    "compilerOptions": {
        "allowJs": true,
        "moduleResolution": "bundler",
        "module": "esnext",
        "target": "esnext",
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "importHelpers": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "stripInternal": true,
        "jsxImportSource": "preact",
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@integration-components/types": ["packages/shared/types/src/index.ts"],
            "@integration-components/types/*": ["packages/shared/types/src/*"],
            "@integration-components/utils": ["packages/shared/utils/src/index.ts"],
            "@integration-components/utils/*": ["packages/shared/utils/src/*"],
            "@integration-components/core": ["packages/shared/core/src/index.ts"],
            "@integration-components/core/*": ["packages/shared/core/src/*"],
            "@integration-components/sdk-internal": ["packages/shared/lib/src/index.ts"],
            "@integration-components/sdk-internal/*": ["packages/shared/lib/src/*"],
            "@integration-components/hooks-preact": ["packages/shared/hooks-preact/src/index.ts"],
            "@integration-components/hooks-preact/*": ["packages/shared/hooks-preact/src/*"],
            "@integration-components/testing": ["packages/shared/testing/src/index.ts"],
            "@integration-components/testing/*": ["packages/shared/testing/src/*"],
            "@integration-components/reports/publish": ["packages/domains/reports/preact/publish/src/index.ts"]
        }
    }
}
