{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmitOnError": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "outDir": "./dist",
        "declarationDir": "./dist/types",
        "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "src/translations/*.json", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist", "config/inject-css.ts", "packages"]
}
